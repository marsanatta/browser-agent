# Copy to .env (git-ignored) before `docker compose up --build`.

# --- Required for any real LLM work ---
# GitHub fine-grained PAT with the "Copilot Requests" permission. The Copilot
# SDK authenticates non-interactively from this env var inside the container —
# there is NO interactive `gh auth login` in the container. Placeholder only.
COPILOT_GITHUB_TOKEN=gho_replace_with_your_token

# Shared secret gating the public agent endpoints (/agent, /sse, /screenshots).
# REQUIRED before exposing the tunnel: a long random secret you share only with
# evaluators. If unset, those endpoints fail closed (503). /health and the
# static frontend stay open. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_ACCESS_TOKEN=replace_with_a_long_random_secret

# --- Required only for the public Cloudflare tunnel (docker compose) ---
# Connector token for a NAMED Cloudflare tunnel (Zero Trust dashboard ->
# Networks -> Tunnels). Named tunnels are required because SSE needs a stable
# connection; quick tunnels do not reliably support it. Placeholder only.
CLOUDFLARE_TUNNEL_TOKEN=replace_with_your_cloudflare_tunnel_token

# --- Optional: target a separately-run Copilot headless server instead of the
# bundled stdio binary. Leave unset for the default (stdio). ---
# COPILOT_HOST=localhost
# COPILOT_PORT=4321

# --- Observability (optional; app boots without these). ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
# LANGFUSE_SECRET_KEY=sk-lf-placeholder
