# Copy to .env (git-ignored) before `docker compose up --build`.

# --- LLM auth: set ONE of these (the Copilot SDK reads them automatically) ---
# EASIEST, no new token — reuse your existing Copilot login. On the HOST run:
#   gh auth token
# and paste the output below as GH_TOKEN. VERIFIED: a real in-container
# /agent/run completed (nominal+verified) with exactly this. There is NO
# interactive login inside the container. (OAuth tokens can expire — re-paste if so.)
GH_TOKEN=paste_output_of_gh_auth_token
#
# OR a GitHub fine-grained PAT owned by your personal account with the
# "Copilot Requests" permission (classic PATs are not supported):
# COPILOT_GITHUB_TOKEN=gho_replace_with_your_token

# Shared secret gating the public agent endpoints (/agent, /sse, /screenshots).
# REQUIRED before exposing the app publicly: a long random secret you share only
# with evaluators. If unset, those endpoints fail closed (503). /health and the
# static frontend stay open. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_ACCESS_TOKEN=replace_with_a_long_random_secret

# --- Optional: target a separately-run Copilot headless server instead of the
# bundled stdio binary. Leave unset for the default (stdio). ---
# COPILOT_HOST=localhost
# COPILOT_PORT=4321

# --- Observability (optional; app boots without these). ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
# LANGFUSE_SECRET_KEY=sk-lf-placeholder
