# Copilot SDK model gateway.
# Default (both unset): stdio against the SDK's bundled binary; auth comes from
#   `gh auth login` / `copilot login`. No separate server needed.
# To target a separately-run headless server instead, set BOTH:
# COPILOT_HOST=localhost
# COPILOT_PORT=4321
# Optional explicit token for the gateway process. Placeholder only.
COPILOT_GITHUB_TOKEN=gho_replace_with_your_token

# Observability (optional; app boots without these).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_SECRET_KEY=sk-lf-placeholder
