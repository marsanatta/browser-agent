# Copilot SDK headless server (model gateway). Start the CLI separately:
#   copilot --headless --port 4321
COPILOT_HOST=localhost
COPILOT_PORT=4321
# Auth for the CLI server process (NOT read by the backend). Placeholder only.
COPILOT_GITHUB_TOKEN=gho_replace_with_your_token

# Observability (optional; app boots without these).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_SECRET_KEY=sk-lf-placeholder
